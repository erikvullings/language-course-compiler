# Copy to .env and fill in. Loaded by course_compiler.settings via python-dotenv.

# Which LLM provider to use: "ollama" or "openai"
LLM_PROVIDER=ollama

# --- Ollama (local, default) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Shared generation defaults
LLM_TEMPERATURE=0.7
LLM_THINKING=false
LLM_TIMEOUT=300
LLM_MAX_RETRIES=2
